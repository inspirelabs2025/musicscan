# Supabase project credentials (replace with your own)
# Find these in Supabase -> Project Settings -> API
SUPABASE_URL="YOUR_SUPABASE_URL"
SUPABASE_PUBLISHABLE_KEY="YOUR_SUPABASE_ANON_KEY"

# Google Analytics Measurement ID
VITE_GA_MEASUREMENT_ID="G-XXXXXXXXXX"

# Client-side exposed environment variables (VITE_ prefix is required)
# Match to the non-VITE_ prefixed variables or set independently
VITE_SUPABASE_URL="YOUR_SUPABASE_URL"
VITE_SUPABASE_PUBLISHABLE_KEY="YOUR_SUPABASE_ANON_KEY"
VITE_SUPABASE_PROJECT_ID="YOUR_SUPABASE_PROJECT_ID"

# AI Nudge variant for A/B testing or feature flagging
VITE_AI_NUDGE_VARIANT="nudge" # or "none", "chat-nudge"
