{
  "version": 2,
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "redirects": [
    { "source": "/art-prints", "destination": "/shop", "permanent": true },
    { "source": "/blog/:slug", "destination": "/plaat-verhaal/:slug", "permanent": true },
    { "source": "/product/:slug/", "destination": "/product/:slug", "permanent": true },
    { "source": "/singles/:slug/", "destination": "/singles/:slug", "permanent": true },
    { "source": "/artists/:slug/", "destination": "/artists/:slug", "permanent": true },
    { "source": "/muziek-verhaal/:slug/", "destination": "/muziek-verhaal/:slug", "permanent": true },
    { "source": "/plaat-verhaal/:slug/", "destination": "/plaat-verhaal/:slug", "permanent": true },
    { "source": "/artist-spotlight/:slug/", "destination": "/artist-spotlight/:slug", "permanent": true },
    { "source": "/anekdotes/:slug/", "destination": "/anekdotes/:slug", "permanent": true },
    { "source": "/nieuws/:slug/", "destination": "/nieuws/:slug", "permanent": true },
    { "source": "/new-release/:slug/", "destination": "/new-release/:slug", "permanent": true },
    { "source": "/nummer/:slug/", "destination": "/nummer/:slug", "permanent": true },
    { "source": "/reviews/:slug/", "destination": "/reviews/:slug", "permanent": true },
    { "source": "/shop/:slug/", "destination": "/shop/:slug", "permanent": true }
  ],
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "https://ssxbpyqnjfiyubsuonar.supabase.co/functions/v1/sitemap-proxy?file=sitemap-index.xml"
    },
    {
      "source": "/sitemaps/:path*",
      "destination": "https://ssxbpyqnjfiyubsuonar.supabase.co/functions/v1/sitemap-proxy?file=:path*"
    },
    {
      "source": "/sm/:path*",
      "destination": "https://ssxbpyqnjfiyubsuonar.supabase.co/functions/v1/sitemap-proxy?file=:path*"
    },
    {
      "source": "/plaat-verhaal/:slug",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "(?i).*(googlebot|bingbot|slurp|duckduckbot|baiduspider|yandexbot|facebookexternalhit|linkedinbot|twitterbot|whatsapp|telegrambot|bot|crawler|spider).*"
        }
      ],
      "destination": "https://ssxbpyqnjfiyubsuonar.supabase.co/functions/v1/universal-ssr-proxy/plaat-verhaal/:slug"
    },
    {
      "source": "/product/:slug",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "(?i).*(googlebot|bingbot|slurp|duckduckbot|baiduspider|yandexbot|facebookexternalhit|linkedinbot|twitterbot|whatsapp|telegrambot|bot|crawler|spider).*"
        }
      ],
      "destination": "https://ssxbpyqnjfiyubsuonar.supabase.co/functions/v1/universal-ssr-proxy/product/:slug"
    },
    {
      "source": "/muziek-verhaal/:slug",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "(?i).*(googlebot|bingbot|slurp|duckduckbot|baiduspider|yandexbot|facebookexternalhit|linkedinbot|twitterbot|whatsapp|telegrambot|bot|crawler|spider).*"
        }
      ],
      "destination": "https://ssxbpyqnjfiyubsuonar.supabase.co/functions/v1/universal-ssr-proxy/muziek-verhaal/:slug"
    },
    {
      "source": "/singles/:slug",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "(?i).*(googlebot|bingbot|slurp|duckduckbot|baiduspider|yandexbot|facebookexternalhit|linkedinbot|twitterbot|whatsapp|telegrambot|bot|crawler|spider).*"
        }
      ],
      "destination": "https://ssxbpyqnjfiyubsuonar.supabase.co/functions/v1/universal-ssr-proxy/singles/:slug"
    },
    {
      "source": "/artists/:slug",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "(?i).*(googlebot|bingbot|slurp|duckduckbot|baiduspider|yandexbot|facebookexternalhit|linkedinbot|twitterbot|whatsapp|telegrambot|bot|crawler|spider).*"
        }
      ],
      "destination": "https://ssxbpyqnjfiyubsuonar.supabase.co/functions/v1/universal-ssr-proxy/artists/:slug"
    },
    {
      "source": "/anekdotes/:slug",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "(?i).*(googlebot|bingbot|slurp|duckduckbot|baiduspider|yandexbot|facebookexternalhit|linkedinbot|twitterbot|whatsapp|telegrambot|bot|crawler|spider).*"
        }
      ],
      "destination": "https://ssxbpyqnjfiyubsuonar.supabase.co/functions/v1/universal-ssr-proxy/anekdotes/:slug"
    },
    {
      "source": "/nieuws/:slug",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "(?i).*(googlebot|bingbot|slurp|duckduckbot|baiduspider|yandexbot|facebookexternalhit|linkedinbot|twitterbot|whatsapp|telegrambot|bot|crawler|spider).*"
        }
      ],
      "destination": "https://ssxbpyqnjfiyubsuonar.supabase.co/functions/v1/universal-ssr-proxy/nieuws/:slug"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/lovable-uploads/:path*",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Vercel-CDN-Cache-Control", "value": "no-store" },
        { "key": "CDN-Cache-Control", "value": "no-store" },
        { "key": "Surrogate-Control", "value": "no-store" },
        { "key": "Pragma", "value": "no-cache" },
        { "key": "Expires", "value": "0" }
      ]
    },
    {
      "source": "/((?!assets|lovable-uploads).*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Vercel-CDN-Cache-Control", "value": "no-store" },
        { "key": "CDN-Cache-Control", "value": "no-store" },
        { "key": "Pragma", "value": "no-cache" }
      ]
    }
  ]
}
